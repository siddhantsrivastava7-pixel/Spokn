{
  "productName": "Spokn",
  "version": "0.1.0",
  "identifier": "app.spokn.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:prerelease",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Spokn",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "publisher": "Siddhant Srivastava",
    "copyright": "Copyright © 2026 Siddhant Srivastava",
    "shortDescription": "Offline speech-to-text",
    "longDescription": "Spokn is a private, offline speech-to-text app. All transcription runs locally — no audio ever leaves your machine.",
    "category": "Productivity",
    "externalBin": ["binaries/spokn-backend"],
    "resources": {
      "resources/whisper/bin/*": "whisper/bin/",
      "resources/whisper/lib/*": "whisper/lib/",
      "resources/whisper/libexec/*": "whisper/libexec/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements.plist",
      "frameworks": []
    }
  }
}
