# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js

# Build outputs
dist/
build/
out/
*.tsbuildinfo

# Rust / Tauri
target/
**/src-tauri/target/
**/src-tauri/gen/schemas/

# Sidecar / compiled backend binaries (keep directory; ignore contents)
apps/*/src-tauri/binaries/*
!apps/*/src-tauri/binaries/.gitkeep
spokn-backend*.exe
spokn-backend

# Bundled whisper runtime — populated by scripts/package-whisper-macos.mjs
# just before `tauri build` on macOS. The bin/ lib/ libexec/ subdirs each
# have a committed PLACEHOLDER that keeps the Tauri resource globs
# non-empty on a fresh clone; everything else is ignored (binary
# artifacts are arch-specific and large). See
# apps/*/src-tauri/resources/README.md for the full layout.
apps/*/src-tauri/resources/whisper/bin/*
apps/*/src-tauri/resources/whisper/lib/*
apps/*/src-tauri/resources/whisper/libexec/*
!apps/*/src-tauri/resources/whisper/bin/PLACEHOLDER
!apps/*/src-tauri/resources/whisper/lib/PLACEHOLDER
!apps/*/src-tauri/resources/whisper/libexec/PLACEHOLDER

# Local app data / cached models (never commit model weights)
# NOTE: do not add `models/` here — there is a source directory
# packages/stt-core/src/models/ that must be committed.
*.gguf
*.bin

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Env / secrets
.env
.env.local
.env.*.local

# Claude Code local settings (user-specific, never committed)
.claude/settings.local.json

# Logs
logs/
*.log

# Temp (includes tmp-handy reference clone, kept local only)
tmp/
tmp-*/
*.tmp

# Test output
coverage/
.nyc_output/
