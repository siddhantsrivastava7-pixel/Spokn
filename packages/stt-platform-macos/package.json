{
  "name": "@stt/platform-macos",
  "version": "0.1.0",
  "description": "macOS runtime adapter for stt-core — offline transcription via whisper.cpp",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@stt/core": "^0.1.0",
    "@huggingface/transformers": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["<rootDir>/tests/**/*.test.ts"],
    "moduleNameMapper": {
      "^@stt/core$": "<rootDir>/../stt-core/src/index.ts"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
