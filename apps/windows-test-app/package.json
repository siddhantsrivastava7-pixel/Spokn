{
  "name": "@stt/windows-test-app",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n core,backend,ui -c yellow,cyan,blue \"npm run dev:core\" \"npm run dev:backend\" \"npm run dev:ui\"",
    "dev:core": "tsc --watch --project ../../packages/stt-core/tsconfig.json",
    "dev:tauri": "concurrently -n backend,tauri -c cyan,green \"npm run dev:backend\" \"npm run tauri dev\"",
    "dev:backend": "tsx watch src-node/server.ts",
    "dev:ui": "vite",
    "tauri": "tauri",
    "build:frontend": "tsc && vite build",
    "build:backend": "node scripts/build-backend.mjs",
    "package:whisper:macos": "node scripts/package-whisper-macos.mjs",
    "build:prerelease": "npm run build:frontend && npm run build:backend",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@stt/core": "*",
    "@stt/platform-windows": "*",
    "@stt/platform-macos": "*",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^4.1.5"
  }
}
